{
  "manifest_version": 3,
  "name": "Sonic Invoices - Instant Price Check",
  "version": "1.0.0",
  "description": "Instantly compare competitor prices against your Shopify store while browsing.",
  "permissions": ["activeTab", "storage", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
