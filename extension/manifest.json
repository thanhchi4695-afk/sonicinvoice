{
  "manifest_version": 3,
  "name": "Sonic Invoices — Margin Guardian",
  "version": "1.1.0",
  "description": "Real-time margin protection for JOOR and NuOrder carts.",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "https://*.jooraccess.com/*",
    "https://app.joor.com/*",
    "https://*.nuorder.com/*",
    "https://xuaakgdkkrrsqxafffyj.supabase.co/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://*.jooraccess.com/*",
        "https://app.joor.com/*",
        "https://*.nuorder.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sonic Invoices"
  },
  "icons": { "48": "icon.png", "128": "icon.png" },
  "externally_connectable": {
    "matches": [
      "https://sonicinvoice.lovable.app/*",
      "https://www.sonicinvoices.com/*",
      "https://sonicinvoices.com/*",
      "https://*.lovable.app/*",
      "http://localhost/*",
      "http://localhost:*/*"
    ]
  }
}
